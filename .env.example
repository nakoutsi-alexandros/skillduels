# ============================================================================
# Skill Duels — environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the two values from your Supabase project.
# `.env` is gitignored — NEVER commit real keys.
#
# Both values come from: Supabase dashboard → Project Settings → API.
# The "anon public" key is SAFE to expose in the browser (Row Level Security is
# what protects your data). Do NOT put the `service_role` key or the database
# password here — those are secrets and must never reach the client bundle.
#
# The VITE_ prefix is required: Vite only exposes prefixed vars to the app.
# If these are left unset, the app still runs — it falls back to the built-in
# demo leaderboard (BOTS) instead of the real backend.
# ============================================================================

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
